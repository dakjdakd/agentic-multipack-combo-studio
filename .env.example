DEMO_MODE=true
APP_ENV=local
APP_DB_URL=sqlite:///./data/app.db
ARTIFACT_DIR=./artifacts
SAMPLES_DIR=./samples

SSB_DB_DIALECT=mysql
SSB_DB_HOST=
SSB_DB_PORT=3306
SSB_DB_USER=
SSB_DB_PASSWORD=
SSB_DB_NAME=
SSB_DB_CHARSET=utf8mb4

LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
VISION_MODEL=

IMAGE_PROVIDER=agnes
IMAGE_BASE_URL=https://apihub.agnes-ai.com
IMAGE_API_KEY=
IMAGE_MODEL=agnes-image-2.1-flash

SEARCH_PROVIDER=tavily
SEARCH_BASE_URL=https://api.tavily.com
SEARCH_API_KEY=

BUDGET_TARGET_RMB=1700
USD_TO_RMB=7.2
LLM_INPUT_USD_PER_MILLION=0.30
LLM_OUTPUT_USD_PER_MILLION=1.20
IMAGE_GENERATION_USD=0.003
SEARCH_REQUEST_USD=0.005
CACHE_TTL_HOURS=24
MAX_IMAGE_RETRIES=2
